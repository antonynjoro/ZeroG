<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access for audio recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Accessibility / Input Monitoring for global hotkey detection (CGEvent tap) -->
    <key>com.apple.security.accessibility</key>
    <true/>
    
    <!-- Network access for optional Gemini API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- App Sandbox disabled for CGEvent posting (text injection) -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
